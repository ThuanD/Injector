{
  "manifest_version": 3,
  "name": "Injector - Auto-inject your scripts",
  "short_name": "Injector",
  "version": "2.0.4",
  "description": "Run custom JavaScript code on specific websites automatically. Manage scripts per domain.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage", "scripting"],
  "host_permissions": ["*://*/*", "https://api.telegram.org/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Injector - Manage your scripts"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "options_page": "options.html"
}
